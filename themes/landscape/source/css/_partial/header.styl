#header
  position: relative
  padding: var(--space-md) 0

#header-outer
  position: relative
  clearfix()

#header-title
  float: left
  @media mq-mobile
    float: none
    text-align: center

#logo
  text-decoration: none
  color: var(--text)
  font-weight: 700
  font-size: 16px
  line-height: 1.2
  letter-spacing: -0.3px

#subtitle-wrap
  margin-top: 4px

#subtitle
  text-decoration: none
  color: var(--muted)
  font-size: 13px
  line-height: 1.2
  letter-spacing: 0

#header-inner
  float: right
  @media mq-mobile
    float: none
    text-align: center
    margin-top: var(--space-sm)

#main-nav
  float: left
  margin-left: -15px
  @media mq-mobile
    float: none
    margin-left: 0

$nav-link
  float: left
  color: var(--text)
  opacity: 0.8
  text-decoration: none
  transition: color 0.2s
  display: block
  padding: 4px 15px
  font-size: 14px
  font-weight: 500
  &:hover
    color: var(--primary)
    opacity: 1

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 4px 12px
  position: relative
  cursor: pointer

.main-nav-link
  @extend $nav-link
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: -15px
  @media mq-mobile
    float: none
    margin-right: 0

#search-form-wrap
  position: absolute
  top: 0
  width: 150px
  height: 30px
  right: -150px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%
    top: auto
    margin-top: var(--space-sm)

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: var(--surface)
  padding: 5px 15px
  border-radius: var(--radius-md)
  border: 1px solid var(--border)

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: var(--muted)
  cursor: pointer
  &:hover, &:focus
    color: var(--text)
