.article
  margin: 48px 0

.article-inner
  overflow: hidden

.article-meta
  clearfix()
  margin-bottom: 8px

.article-date
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 1px
  color: color-grey
  line-height: 1em
  font-weight: 500
  font-size: 12px
  float: left

.article-category
  float: left
  line-height: 1em
  color: var(--muted)
  margin-left: 8px
  &:before
    content: "\2022"

.article-category-link
  @extend $block-caption
  margin: 0 12px 1em

.article-header
  padding: 0

.article-title
  text-decoration: none
  font-size: 24px
  font-weight: 700
  color: color-default
  line-height: line-height-title
  transition: color 0.2s
  letter-spacing: -0.3px
  a&:hover
    color: color-link

.article-entry
  @extend $base-style
  clearfix()
  color: color-default
  padding: 0
  font-size: 16px
  line-height: 1.75
  p, table
    line-height: 1.75
    margin: var(--space-md) 0
  h1, h2, h3, h4, h5, h6
    font-weight: 700
    line-height: line-height-title
    margin: var(--space-xl) 0 var(--space-md)
    letter-spacing: -0.3px
  h1
    font-size: 28px
    padding-bottom: var(--space-sm)
    border-bottom: 1px solid var(--border)
  h2
    font-size: 22px
  h3
    font-size: 18px
  a
    color: color-link
    text-decoration: none
    &:hover
      text-decoration: underline
  ul, ol, dl
    margin-top: var(--space-md)
    margin-bottom: var(--space-md)
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: auto
    border-radius: var(--radius-lg)
  iframe
    border: none
  table
    width: 100%
    border-collapse: collapse
    background: var(--surface)
    border: 1px solid var(--border)
    border-radius: var(--radius-lg)
    overflow: hidden
    font-size: 14px
  th
    background: var(--surface2)
    font-weight: 600
    text-align: left
    padding: var(--space-sm) var(--space-md)
    border-bottom: 1px solid var(--border)
    color: var(--text)
    font-size: 12px
    text-transform: uppercase
    letter-spacing: 0.05em
  td
    padding: var(--space-sm) var(--space-md)
    border-bottom: 1px solid var(--border)
    color: var(--text)
  tr:last-child td
    border-bottom: none
  tr:hover
    background: var(--surface2)
  blockquote
    margin: var(--space-lg) 0
    padding: var(--space-sm) var(--space-md)
    border-left: 3px solid var(--primary)
    background: var(--surface2)
    color: var(--muted)
    font-family: font-sans
    text-align: left
    p
      margin: var(--space-sm) 0
  .pullquote
    text-align: left
    width: 45%
    margin: 0
    &.left
      margin-left: 0.5em
      margin-right: 1em
    &.right
      margin-right: 0.5em
      margin-left: 1em
  .caption
    color: color-grey
    display: block
    font-size: 0.9em
    margin-top: 0.5em
    position: relative
    text-align: center
  .video-container
    position: relative
    padding-top: (9 / 16 * 100)%
    height: 0
    overflow: hidden
    iframe, object, embed
      position: absolute
      top: 0
      left: 0
      width: 100%
      height: 100%
      margin-top: 0

.article-more-link a
  display: inline-block
  line-height: 1em
  padding: 8px 0
  color: var(--primary)
  text-decoration: none
  font-size: 14px
  font-weight: 600
  transition: color 0.2s
  &:hover
    color: var(--text)
    text-decoration: none

.article-footer
  clearfix()
  font-size: 0.85em
  line-height: line-height
  border-top: 1px solid color-border
  padding-top: var(--space-md)
  margin: var(--space-lg) 0 0
  a
    color: color-grey
    text-decoration: none
    &:hover
      color: color-default

// Post page styling (non-index)
.article:not(.article-index)
  margin: 24px 0 48px
  .article-header
    padding: 0
    margin-bottom: 8px
  .article-title
    font-size: 32px
    letter-spacing: -0.5px
    line-height: 1.2
  .article-meta
    margin-bottom: 24px
  .article-entry
    padding: 0

// Home page article list styling
.article-index
  margin: 40px 0
  padding-bottom: 40px
  border-bottom: 1px solid var(--border)
  &:last-child
    border-bottom: none
  .article-title
    font-size: 22px
    margin-bottom: 8px
  .article-meta
    margin-bottom: 12px
  .article-entry
    font-size: 15px
    line-height: 1.7
    color: var(--muted)
    p
      margin: 0 0 var(--space-sm)
  .article-footer
    display: none

.article-tag-list-item
  float: left
  margin-right: 10px

.article-tag-list-link
  &:before
    content: "#"

.article-comment-link
  float: right
  &:before
    padding-right: 8px

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  &:before
    padding-right: 6px

#article-nav
  clearfix()
  position: relative
  @media mq-normal
    margin: block-margin 0
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: color-border

.article-nav-link-wrap
  text-decoration: none
  color: color-grey
  box-sizing: border-box
  margin-top: block-margin
  text-align: center
  display: block
  &:hover
    color: color-default
  @media mq-normal
    width: 50%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 2px
  color: color-border
  line-height: 1em
  font-weight: bold
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.85em
  line-height: line-height
  margin-top: 0.5em

.article-share-box
  position: absolute
  display: none
  background: var(--surface)
  border: 1px solid var(--border)
  border-radius: var(--radius-lg)
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1)
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: color-default
  outline: none
  border: 1px solid color-border
  border-radius: var(--radius-lg) var(--radius-lg) 0 0
  height: 36px
  line-height: 36px

.article-share-links
  clearfix()
  background: var(--surface2)

$article-share-link
  width: 50px
  height: 36px
  display: block
  float: left
  position: relative
  color: var(--muted)
  .fa
    font-size: 20px
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:hover
    background: color-twitter

.article-share-facebook
  @extend $article-share-link
  &:hover
    background: color-facebook

.article-share-pinterest
  @extend $article-share-link
  &:hover
    background: color-pinterest

.article-share-linkedin
  @extend $article-share-link
  &:hover
    background: color-linkedin

.article-gallery
  background: #000
  position: relative

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    margin: 0 auto
