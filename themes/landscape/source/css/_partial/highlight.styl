// UI.md Syntax Highlight colors mapped
highlight-background = var(--surface2)
highlight-foreground = var(--text)
highlight-comment = var(--muted)
highlight-keyword = var(--primary)
highlight-string = var(--info)
highlight-function = var(--warning)
highlight-number = var(--warning)
highlight-tag = var(--danger)
highlight-attr = var(--text)
highlight-built_in = var(--warning)

$code-block
  background: highlight-background
  margin: 0 article-padding * -1
  padding: var(--space-md) article-padding
  border-style: solid
  border-color: color-border
  border-width: 1px 0
  overflow: auto
  color: highlight-foreground
  line-height: 1.6
  font-size: 13px
  font-family: font-mono

$line-numbers
  color: var(--muted)
  font-size: 0.85em

.article-entry
  pre, code
    font-family: font-mono
  code
    background: var(--surface2)
    padding: 2px 6px
    border-radius: var(--radius-sm)
    font-size: 0.9em
  pre
    @extend $code-block
    code
      background: none
      padding: 0
      border-radius: 0
  .highlight
    @extend $code-block
    border-radius: var(--radius-lg)
    border-width: 1px
    margin: var(--space-md) 0
    pre
      border: none
      margin: 0
      padding: 0
    table
      margin: 0
      width: auto
      border: none
    td
      border: none
      padding: 0
    figcaption
      clearfix()
      font-size: 0.85em
      color: highlight-comment
      line-height: 1em
      margin-bottom: 1em
      a
        float: right
    .gutter
      -moz-user-select: none
      -ms-user-select: none
      -webkit-user-select: none
      user-select: none
      pre
        @extend $line-numbers
        text-align: right
        padding-right: 20px
    .line
      height: 1.6em
    .line.marked
      background: rgba(16, 163, 127, 0.1)
  .gist
    margin: 0 article-padding * -1
    border-style: solid
    border-color: color-border
    border-width: 1px 0
    background: highlight-background
    padding: var(--space-md) article-padding var(--space-md) 0
    .gist-file
      border: none
      font-family: font-mono
      margin: 0
      .gist-data
        background: none
        border: none
        .line-numbers
          @extend $line-numbers
          background: none
          border: none
          padding: 0 20px 0 0
        .line-data
          padding: 0 !important
      .highlight
        margin: 0
        padding: 0
        border: none
      .gist-meta
        background: highlight-background
        color: highlight-comment
        font: 0.85em font-sans
        padding: 0
        margin-top: 1em
        margin-left: article-padding
        a
          color: color-link
          font-weight: normal
          &:hover
            text-decoration: underline

pre
  .comment
  .title
    color: highlight-comment
  .variable
  .attribute
  .tag
  .regexp
  .ruby .constant
  .xml .tag .title
  .xml .pi
  .xml .doctype
  .html .doctype
  .css .id
  .css .class
  .css .pseudo
    color: highlight-tag
  .number
  .preprocessor
  .built_in
  .literal
  .params
  .constant
    color: highlight-number
  .class
  .ruby .class .title
  .css .rules .attribute
    color: highlight-keyword
  .string
  .value
  .inheritance
  .header
  .ruby .symbol
  .xml .cdata
    color: highlight-string
  .css .hexcolor
    color: highlight-function
  .function
  .python .decorator
  .python .title
  .ruby .function .title
  .ruby .title .keyword
  .perl .sub
  .javascript .title
  .coffeescript .title
    color: highlight-function
  .keyword
  .javascript .function
    color: highlight-keyword
