@media mq-mobile
  #mobile-nav
    position: absolute
    top: 0
    left: 0
    width: mobile-nav-width
    height: 100%
    background: color-mobile-nav-background
    border-right: 1px solid var(--border)

@media mq-mobile
  .mobile-nav-link
    display: block
    color: var(--text)
    text-decoration: none
    padding: 15px 20px
    font-weight: 500
    &:hover
      background: var(--surface)
