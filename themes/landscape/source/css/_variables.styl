// Config
support-for-ie = false
vendor-prefixes = webkit moz ms official

// CSS Variables (Minimal UI Design System from Cashier UI.md)
:root
  color-scheme: light
  --primary: #10a37f
  --bg: #ffffff
  --surface: #ffffff
  --surface2: #f7f7f8
  --text: #343541
  --muted: #71717a
  --border: #e5e5e5
  --ring: #10a37f
  --danger: #ef4444
  --warning: #f59e0b
  --info: #3b82f6
  --radius: 8px
  --radius-sm: 4px
  --radius-md: 6px
  --radius-lg: 8px
  --radius-xl: 12px
  --space-xs: 4px
  --space-sm: 8px
  --space-md: 16px
  --space-lg: 24px
  --space-xl: 32px

@media (prefers-color-scheme: dark)
  :root
    color-scheme: dark
    --bg: #343541
    --surface: #444654
    --surface2: #202123
    --text: #ececf1
    --muted: #8e8ea0
    --border: #565869

// Stylus variables mapped to CSS vars
color-default = var(--text)
color-grey = var(--muted)
color-border = var(--border)
color-link = var(--primary)
color-background = var(--bg)
color-sidebar-text = var(--muted)
color-widget-background = var(--surface)
color-widget-border = var(--border)
color-footer-background = var(--bg)
color-mobile-nav-background = var(--surface2)
color-twitter = #00aced
color-facebook = #3b5998
color-pinterest = #cb2027
color-linkedin = #0077B5

// Fonts
font-sans = Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen", "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans", "Helvetica Neue", sans-serif
font-serif = Georgia, "Times New Roman", serif
font-mono = "JetBrains Mono", "Fira Code", "SF Mono", Consolas, Monaco, monospace
font-icon = ForkAwesome
font-size = 16px
line-height = 1.75em
line-height-title = 1.3em

// Header
logo-size = 40px
subtitle-size = 16px
banner-height = 0
banner-url = hexo-config("banner")

sidebar = hexo-config("sidebar")

// Layout
block-margin = 32px
article-padding = 24px
mobile-nav-width = 280px
main-column = 9
sidebar-column = 3

if sidebar and sidebar isnt bottom
  _sidebar-column = sidebar-column
else
  _sidebar-column = 0

// Grids
column-width = 80px
gutter-width = 20px
columns = main-column + _sidebar-column

// Media queries
mq-mobile = "screen and (max-width: 767px)"
mq-normal = "screen and (min-width: 768px)"
