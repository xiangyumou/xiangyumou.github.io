$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 1px
  color: color-grey
  margin-bottom: 1em
  margin-left: 0
  line-height: 1em
  font-weight: 600
  font-size: 12px

$block
  background: var(--surface)
  border: 1px solid var(--border)
  border-radius: var(--radius-xl)

$base-style
  h1
    font-size: 24px
  h2
    font-size: 20px
  h3
    font-size: 16px
  h4
    font-size: 14px
  h5
    font-size: 14px
  h6
    font-size: 14px
    color: color-grey
  hr
    border: none
    height: 1px
    background: color-border
    margin: var(--space-lg) 0
  strong
    font-weight: 600
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted
  ul, ol, dl
    margin: var(--space-md) 0
    padding-left: var(--space-lg)
    line-height: line-height
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: disc
  ol
    list-style: decimal
  dt
    font-weight: 600
